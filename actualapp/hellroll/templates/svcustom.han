kind: Service
apiVersion: v1
metadata:
  name: rollout-bluegreen-active

spec:
  type: LoadBalancer
  selector:
{{ toYaml .Values.labels | nindent 6 }}
  ports:
  - protocol: TCP
    port: 80
    targetPort: 80

---
kind: Service

apiVersion: v1
metadata:
  name: rollout-bluegreen-preview
spec:
  type: LoadBalancer
  selector:
{{ toYaml .Values.labels | nindent 6 }}
  ports:
  - protocol: TCP
    port: 80
    targetPort: 80